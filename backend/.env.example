# PlumeTrace Backend Environment Configuration

# FastAPI Global Protection Key (Required)
PLUMETRACE_API_KEY=your_secure_api_key_here

# MQTT Broker Authentication
MQTT_USERNAME=plumetrace
MQTT_PASSWORD=secure_plume_demo

# AI Integration (At least one is required if not using offline deterministic mode)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Optional Advanced Configuration
# PLUMETRACE_OPENAI_MODEL=gpt-4o-mini
# PLUMETRACE_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# PLUMETRACE_CONFIDENCE_GATE=0.6
